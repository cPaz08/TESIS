.right-column { display: flex; flex-direction: column; gap: 15px; }.status-card { padding: 19px; }.status-card .card-heading > svg { color: #9aa29d; }.health-score { margin-top: 20px; display: flex; align-items: center; gap: 15px; }.score-ring { width: 68px; height: 68px; flex: 0 0 auto; border-radius: 50%; display: grid; place-content: center; text-align: center; background: radial-gradient(circle at center, white 59%, transparent 61%), conic-gradient(#5b8b68 98%, #e7ece8 0); }.score-ring strong { font: 800 18px 'Manrope'; line-height: 1; }.score-ring small { color: #9aa29d; font-size: 7px; }.health-score > span { display: flex; flex-direction: column; gap: 3px; }.health-score > span strong { color: #568162; font: 800 14px 'Manrope'; }.health-score > span small { color: #929b95; font-size: 8px; }.health-list { margin-top: 19px; border-top: 1px solid #edf0ed; }.health-list > div { min-height: 40px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #f0f2f0; }.health-list span { display: inline-flex; align-items: center; gap: 8px; color: #68736c; font-size: 8px; }.health-list span svg { color: #8b958f; }.health-list strong { font-size: 8px; }.health-list strong.good { color: #588466; }
