  .dashboard-page { display: block; }.dashboard-sidebar, .dashboard-topbar { display: none; }.dashboard-mobile-header { height: 66px; padding: 0 16px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e4e8e4; background: rgba(255,255,255,.92); position: sticky; top: 0; z-index: 5; }.dashboard-mobile-header button { width: 38px; height: 38px; display: grid; place-items: center; border: 1px solid #e0e5e1; border-radius: 10px; background: white; }.mobile-nav-popover { position: fixed; z-index: 8; right: 15px; top: 58px; width: 180px; padding: 7px; display: flex; flex-direction: column; border: 1px solid #e1e5e1; border-radius: 12px; background: white; box-shadow: 0 15px 35px rgba(45,62,53,.15); }.mobile-nav-popover button { min-height: 38px; border: 0; border-radius: 8px; display: flex; align-items: center; gap: 9px; background: transparent; font-size: 11px; }.dashboard-content { padding: 24px 15px 45px; }.dashboard-welcome { align-items: flex-start; }.dashboard-welcome h1 { font-size: 25px; }.dashboard-welcome p { line-height: 1.5; }.online-status { display: none; }.mode-banner { align-items: flex-start; flex-wrap: wrap; }.mode-banner button { margin-left: 25px; }.metrics-grid { grid-template-columns: 1fr 1fr; }.system-card { grid-column: 1 / 3; }.chart-card { padding: 15px; min-height: 390px; }.card-heading { flex-direction: column; }.chart-controls { width: 100%; justify-content: space-between; }.main-chart { height: 210px; }.right-column { grid-template-columns: 1fr; }.records-card { padding: 15px; }.records-card .card-heading { flex-direction: row; }.modal-card { padding: 28px 20px; }
}

@media (max-width: 430px) {
  .hero h1 { font-size: 42px; }.hero-visual { min-height: 350px; }.preview-window { scale: .94; }.floating-alert { scale: .9; transform-origin: bottom right; }.preview-heading strong { font-size: 12px; }.mini-card { padding: 9px; }.mini-card strong { font-size: 20px; }.preview-chart-card { margin-top: 7px; }.steps-grid article { min-height: 195px; }.flow-main { width: min(100% - 22px, 510px); }.metrics-grid { grid-template-columns: 1fr; }.system-card { grid-column: auto; }.metric-card { min-height: 155px; }.chart-controls { align-items: flex-start; flex-direction: column; }.chart-area { margin-top: 15px; }.chart-legend { flex-direction: column; gap: 6px; }.records-card .card-heading { align-items: center; }.export-button { flex: 0 0 auto; }
}
