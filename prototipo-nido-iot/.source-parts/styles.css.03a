.dashboard-content { max-width: 1420px; padding: 34px 34px 55px; margin: 0 auto; }.dashboard-welcome { display: flex; justify-content: space-between; align-items: flex-end; gap: 30px; }.dashboard-welcome h1 { margin: 6px 0 5px; font: 800 29px 'Manrope'; letter-spacing: -1.2px; }.dashboard-welcome p { margin: 0; color: #768079; font-size: 12px; }.online-status { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }.online-status span { display: inline-flex; align-items: center; gap: 6px; color: #4f815e; font-size: 10px; font-weight: 700; }.online-status i { width: 7px; height: 7px; border-radius: 50%; background: #5e966e; box-shadow: 0 0 0 4px #e7f2e9; }.online-status small { color: #9ba39e; font-size: 8px; }
.mode-banner { margin-top: 20px; min-height: 44px; display: flex; align-items: center; gap: 9px; padding: 8px 10px 8px 13px; border: 1px solid #eedfbf; border-radius: 11px; background: #fff9ed; color: #765d2d; font-size: 10px; }.mode-banner span { flex: 1; }.mode-banner button { border: 0; background: #f3e4c1; border-radius: 8px; padding: 7px 10px; color: #6d5428; font-size: 9px; font-weight: 700; cursor: pointer; }
.metrics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-top: 24px; }.metric-card { min-height: 172px; padding: 19px; background: white; border: 1px solid #e4e8e4; border-radius: 16px; box-shadow: 0 8px 24px rgba(45,62,53,.035); }.metric-top { display: flex; justify-content: space-between; align-items: center; }.metric-top button { border: 0; background: transparent; color: #adb4af; padding: 0; }.metric-icon { width: 39px; height: 39px; display: grid; place-items: center; border-radius: 11px; }.metric-card.temperature .metric-icon { color: var(--orange); background: var(--orange-soft); }.metric-card.humidity .metric-icon { color: var(--blue); background: var(--blue-soft); }.system-card .metric-icon { color: #698170; background: #edf3ee; }.metric-card > span { display: block; margin-top: 17px; color: #7d8780; font-size: 10px; font-weight: 600; }.metric-card > strong { display: block; margin-top: 2px; font: 800 31px 'Manrope'; letter-spacing: -1.5px; }.metric-card sup { margin-left: 3px; color: #59655e; font-size: 13px; }.metric-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 9px; }.metric-footer span { display: inline-flex; align-items: center; gap: 5px; color: #568264; font-size: 8px; font-weight: 700; }.metric-footer i { width: 5px; height: 5px; border-radius: 50%; background: #67a176; }.metric-footer small { color: #9ba39e; font-size: 8px; }.metric-card .system-value { color: var(--green-dark); font-size: 27px; }
.dashboard-layout { display: grid; grid-template-columns: minmax(0, 1.75fr) minmax(280px, .7fr); gap: 15px; margin-top: 15px; }.dashboard-card { background: white; border: 1px solid #e4e8e4; border-radius: 16px; box-shadow: 0 8px 24px rgba(45,62,53,.03); }.chart-card { min-height: 430px; padding: 20px; }.card-heading { display: flex; align-items: flex-start; justify-content: space-between; gap: 20px; }.card-heading > div:first-child { display: flex; flex-direction: column; gap: 4px; }.card-heading span { font-size: 12px; font-weight: 800; }.card-heading small { color: #929b95; font-size: 8px; }.chart-controls { display: flex; align-items: center; gap: 8px; }.metric-switch { padding: 3px; background: #f1f3f0; border-radius: 8px; }.metric-switch button { border: 0; border-radius: 6px; padding: 6px 9px; background: transparent; color: #89928c; font-size: 8px; cursor: pointer; }.metric-switch button.active { background: white; color: var(--ink); box-shadow: 0 2px 7px rgba(45,62,53,.08); font-weight: 700; }.chart-controls select { height: 29px; border: 1px solid #e1e5e1; border-radius: 8px; background: white; color: #6f7973; padding: 0 7px; font-size: 8px; outline: 0; }.chart-area { display: grid; grid-template-columns: 31px 1fr; margin-top: 23px; }.chart-y-labels { display: flex; flex-direction: column; justify-content: space-between; padding: 1px 0 8px; color: #a0a8a3; font-size: 7px; }.main-chart { width: 100%; height: 245px; overflow: visible; color: var(--orange); }.main-chart.humidity { color: var(--blue); }.chart-grid { stroke: #eef1ee; stroke-width: 1; stroke-dasharray: 4 5; }.chart-polyline { fill: none; stroke: currentColor; stroke-width: 2.3; stroke-linecap: round; stroke-linejoin: round; }.chart-cursor { stroke: currentColor; stroke-width: 1; stroke-dasharray: 3 4; opacity: .45; }.chart-point { fill: white; stroke: currentColor; stroke-width: 3; }.chart-x-labels { display: flex; justify-content: space-between; padding-left: 31px; margin-top: -3px; color: #9da59f; font-size: 7px; }.chart-legend { display: flex; gap: 19px; margin: 18px 0 0 31px; color: #7e8881; font-size: 8px; }.chart-legend span { display: inline-flex; align-items: center; gap: 6px; }.chart-legend i { width: 14px; height: 3px; border-radius: 2px; background: var(--orange); }.chart-legend i.humidity { background: var(--blue); }.chart-legend i.ideal { height: 7px; background: #e8ece8; }
